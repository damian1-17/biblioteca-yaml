  "item": [
    {
      "name": "Autores",
      "item": [
        {
          "name": "1. Listar todos los autores",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/autores"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Responde con array', () => { pm.expect(pm.response.json()).to.be.an('array'); });",
                  "pm.test('Campos del contrato en cada autor', () => {",
                  "  const arr = pm.response.json();",
                  "  if (arr.length > 0) {",
                  "    pm.expect(arr[0]).to.have.property('id_autor');",
                  "    pm.expect(arr[0]).to.have.property('nombre');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Crear un nuevo autor",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/autores",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nombre\": \"Octavio Paz\", \"nacionalidad\": \"Mexicana\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Campos del contrato presentes', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id_autor');",
                  "  pm.expect(json).to.have.property('nombre');",
                  "  pm.expect(json.nombre).to.eql('Octavio Paz');",
                  "  pm.expect(json.nacionalidad).to.eql('Mexicana');",
                  "});",
                  "pm.test('id_autor es número', () => { pm.expect(pm.response.json().id_autor).to.be.a('number'); });",
                  "pm.collectionVariables.set('id_autor', pm.response.json().id_autor);"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Obtener autor por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/autores/{{id_autor}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Campos del contrato exactos', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id_autor');",
                  "  pm.expect(json).to.have.property('nombre');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4. Obtener autor inexistente (404)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/autores/99999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 para autor inexistente', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },
        {
          "name": "5. Actualizar autor por ID",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/autores/{{id_autor}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nombre\": \"Octavio Paz Lozano\", \"nacionalidad\": \"Mexicana\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
