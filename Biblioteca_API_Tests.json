{
  "info": {
    "name": "Biblioteca API - Tests v3",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "id_autor", "value": "" },
    { "key": "id_autor_libros", "value": "" },
    { "key": "id_autor_prestamos", "value": "" },
    { "key": "id_libro", "value": "" },
    { "key": "id_libro_prestamos", "value": "" },
    { "key": "id_usuario", "value": "" },
    { "key": "id_usuario_prestamos", "value": "" },
    { "key": "id_prestamo", "value": "" }
  ],
  "item": [
    {
      "name": "Autores",
      "item": [
        {
          "name": "1. Listar todos los autores",
          "request": { "method": "GET", "url": "{{baseUrl}}/autores" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => { pm.response.to.have.status(200); });",
            "pm.test('Respuesta es un array', () => { pm.expect(pm.response.json()).to.be.an('array'); });",
            "pm.test('Estructura del autor es correcta', () => {",
            "    const autores = pm.response.json();",
            "    if (autores.length > 0) {",
            "        pm.expect(autores[0]).to.have.property('id_autor').that.is.a('number');",
            "        pm.expect(autores[0]).to.have.property('nombre').that.is.a('string');",
            "    }",
            "});"
          ]}}]
        },
        {
          "name": "2. Crear un nuevo autor",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/autores",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Autor Test\",\n  \"nacionalidad\": \"Ecuatoriana\"\n}" }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": [
                "pm.collectionVariables.set('ts', Date.now());"
              ]}
            },
            {
              "listen": "test",
              "script": { "exec": [
                "pm.test('Status 201 Created', () => { pm.response.to.have.status(201); });",
                "pm.test('Respuesta tiene estructura correcta', () => {",
                "    const autor = pm.response.json();",
                "    pm.expect(autor).to.have.property('id_autor').that.is.a('number');",
                "    pm.expect(autor).to.have.property('nombre').that.is.a('string');",
                "    pm.collectionVariables.set('id_autor', autor.id_autor);",
                "});"
              ]}
            }
          ]
        },
        {
          "name": "3. Obtener autor por ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/autores/{{id_autor}}" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => { pm.response.to.have.status(200); });",
            "pm.test('Estructura del autor es correcta', () => {",
            "    const autor = pm.response.json();",
            "    pm.expect(autor).to.have.property('id_autor').that.is.a('number');",
            "    pm.expect(autor).to.have.property('nombre').that.is.a('string');",
            "});"
          ]}}]
        },
        {
          "name": "4. Actualizar autor por ID",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/autores/{{id_autor}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Autor Test Actualizado\",\n  \"nacionalidad\": \"Ecuatoriana\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => { pm.response.to.have.status(200); });",
            "pm.test('Estructura actualizada es correcta', () => {",
            "    const autor = pm.response.json();",
            "    pm.expect(autor).to.have.property('id_autor').that.is.a('number');",
            "    pm.expect(autor).to.have.property('nombre').that.is.a('string');",
            "});"
          ]}}]
        },
        {
          "name": "5. Listar libros de un autor",
          "request": { "method": "GET", "url": "{{baseUrl}}/autores/{{id_autor}}/libros" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => { pm.response.to.have.status(200); });",
            "pm.test('Respuesta es un array', () => { pm.expect(pm.response.json()).to.be.an('array'); });",
            "pm.test('Estructura libro-autor es correcta', () => {",
            "    const libros = pm.response.json();",
            "    if (libros.length > 0) {",
            "        pm.expect(libros[0]).to.have.property('id_libro').that.is.a('number');",
            "        pm.expect(libros[0]).to.have.property('id_autor').that.is.a('number');",
            "    }",
            "});"
          ]}}]
        },
        {
          "name": "6. Eliminar autor por ID",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/autores/{{id_autor}}" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204 No Content', () => { pm.response.to.have.status(204); });"
          ]}}]
        }
      ]
    },
