            "pm.test('Status 200 OK', () => { pm.response.to.have.status(200); });",
            "pm.test('Estructura del préstamo es correcta', () => {",
            "    const prestamo = pm.response.json();",
            "    pm.expect(prestamo).to.have.property('id_prestamo').that.is.a('number');",
            "    pm.expect(prestamo).to.have.property('id_libro').that.is.a('number');",
            "    pm.expect(prestamo).to.have.property('id_usuario').that.is.a('number');",
            "    pm.expect(prestamo).to.have.property('estado');",
            "    pm.expect(['activo', 'devuelto', 'vencido']).to.include(prestamo.estado);",
            "});"
          ]}}]
        },
        {
          "name": "4. Actualizar préstamo (registrar devolución)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/prestamos/{{id_prestamo}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fecha_devolucion_real\": \"2026-04-25\",\n  \"estado\": \"devuelto\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => { pm.response.to.have.status(200); });",
            "pm.test('Estructura actualizada es correcta', () => {",
            "    const prestamo = pm.response.json();",
            "    pm.expect(prestamo).to.have.property('id_prestamo').that.is.a('number');",
            "    pm.expect(prestamo).to.have.property('estado');",
            "    pm.expect(['activo', 'devuelto', 'vencido']).to.include(prestamo.estado);",
            "});"
          ]}}]
        },
        {
          "name": "5. Eliminar préstamo por ID",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/prestamos/{{id_prestamo}}" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204 No Content', () => { pm.response.to.have.status(204); });"
          ]}}]
        },
        {
          "name": "6. Teardown - Eliminar libro del préstamo",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/libros/{{id_libro_prestamos}}" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Teardown libro OK', () => { pm.response.to.have.status(204); });"
          ]}}]
        },
        {
          "name": "7. Teardown - Eliminar usuario del préstamo",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/usuarios/{{id_usuario_prestamos}}" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Teardown usuario OK', () => { pm.response.to.have.status(204); });"
          ]}}]
        },
